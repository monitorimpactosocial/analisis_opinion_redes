# Copy to .env and fill only on the machine that will run the trial.
# Never commit .env or credential JSON files.

# Meta Graph API
META_GRAPH_VERSION=v23.0
META_ACCESS_TOKEN=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_SINCE_DAYS=1
META_LIMIT_POSTS=25
META_LIMIT_COMMENTS_PER_POST=100

# Privacy defaults
ANONYMIZATION_SALT=replace-with-random-local-secret
STORE_AUTHOR_NAME=false

# Google destinations supplied for the trial
GOOGLE_SPREADSHEET_ID=19qCi8dMDZa89OrZhUth5EhQ0qvkrup6PaqTN3BN7NCc
GOOGLE_DRIVE_FOLDER_ID=1RGaWR4DJLrjHRNOoDEw7tdELaAYACcLd
WRITE_GOOGLE=false

# Google authentication options:
# 1) Service account shared with the spreadsheet/folder:
# GOOGLE_APPLICATION_CREDENTIALS=C:\secure\service_account.json
# 2) Application default credentials:
# gcloud auth application-default login

